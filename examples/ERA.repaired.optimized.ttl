:PlatformEdge a owl:Class;
  rdfs:subClassOf :InfrastructureObject;
  :rinfIndex "1.2.1.0.6";
  dct:created "2021-08-02"^^xsd:date;
  dct:modified "2023-11-10"^^xsd:date;
  rdfs:comment "Platform for the purpose of RINF is understood as a platform edge. A platform concerns only the part of the structure neighbouring to the track (interfaced with trains)."@en;
  rdfs:isDefinedBy <http://data.europa.eu/949/>;
  rdfs:label "Platform edge"@en;
  rdfs:seeAlso <https://wiki3.railml.org/DataModel/3.2/IS/EARoot/EA250.htm>;
  swvs:term_status "stable" .

:RaisedPantographsDistanceAndSpeed a owl:Class;
  dct:created "2023-04-05"^^xsd:date;
  rdfs:comment """Indication of maximum number of raised pantographs per train allowed and minimum spacing centre line to centre line of adjacent pantograph heads, expressed in metres, at the given speed.
Each track can have several raised pantographs per train allowed (structured) values, and each one has values for number of pantographs, minimum distance between pantographs, in metres, and speed considered in km/h."""@en;
  rdfs:isDefinedBy <http://data.europa.eu/949/>;
  rdfs:label "Raised pantographs distance and speed"@en;
  swvs:term_status "stable" .

